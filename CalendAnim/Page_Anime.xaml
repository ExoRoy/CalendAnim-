<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalendAnim.Page_Anime"
             Title="Détails"
             BackgroundColor="#121212"> <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="20">

            <Grid ColumnDefinitions="120, *" ColumnSpacing="15">
                <Border Grid.Column="0" StrokeShape="RoundRectangle 8" StrokeThickness="0" HeightRequest="170">
                    <Image Source="{Binding Images.Jpg.ImageUrl}" Aspect="AspectFill" />
                </Border>

                <VerticalStackLayout Grid.Column="1" Spacing="5" VerticalOptions="Center">
                    <Label Text="{Binding Title}" FontSize="22" FontAttributes="Bold" TextColor="White" MaxLines="3" LineBreakMode="TailTruncation" />
                    <Label Text="{Binding Status}" FontSize="14" TextColor="#B3B3B3" Margin="0,5,0,0"/>
                    <Label x:Name="EnCours" FontSize="12" TextColor="#8A8A8A" />
                </VerticalStackLayout>
            </Grid>

            <Grid ColumnDefinitions="*, *, *, *" Margin="0, 10">
                
                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="5">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer x:Name="TapAjouterFavori" Tapped="OnAjouterFavoriClicked" />
                    </VerticalStackLayout.GestureRecognizers>
                    
                    <Label x:Name="IconeFavori" Text="🤍" FontSize="24" HorizontalOptions="Center" />
                    <Label x:Name="TexteFavori" Text="Ajouter" FontSize="12" TextColor="White" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="5">
                    <Label Text="⏳" FontSize="24" HorizontalOptions="Center" />
                    <Label Text="En attente" FontSize="12" TextColor="#B3B3B3" />
                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="5">
                    <Label Text="🔄" FontSize="24" HorizontalOptions="Center" />
                    <Label Text="Suivi" FontSize="12" TextColor="#B3B3B3" />
                </VerticalStackLayout>
                
                <VerticalStackLayout Grid.Column="3" HorizontalOptions="Center" Spacing="5">
                    <Label Text="🌐" FontSize="24" HorizontalOptions="Center" />
                    <Label Text="WebView" FontSize="12" TextColor="#B3B3B3" />
                </VerticalStackLayout>
            </Grid>

            <Label Text="{Binding Synopsis}" FontSize="14" TextColor="#CCCCCC" MaxLines="4" LineBreakMode="TailTruncation" LineHeight="1.3" />

            <Label x:Name="GenresLabel" TextColor="White" FontSize="14" FontAttributes="Bold" />
            
            <Label x:Name="TitreSectionEpisodes" Text="Épisodes" FontSize="18" FontAttributes="Bold" TextColor="White" Margin="0, 20, 0, 10" />
            <ActivityIndicator x:Name="EpisodeSpinner" IsRunning="True" IsVisible="True" Color="#8A2BE2" HeightRequest="30" />

            <VerticalStackLayout x:Name="ListeEpisodesContainer" 
                                 Spacing="15"
                                 BindableLayout.ItemsSource="{Binding ListeEpisodes}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        
                        <Grid ColumnDefinitions="*, Auto" Padding="0, 5, 0, 15">
                            
                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <Label Text="{Binding Title}" 
                                       TextColor="#E0E0E0" 
                                       FontSize="15" 
                                       FontAttributes="Bold"
                                       MaxLines="1"
                                       LineBreakMode="TailTruncation"/>
                                       
                                <Label Text="{Binding Aired, StringFormat='Sorti le : {0:d}'}" 
                                       TextColor="#8A8A8A" 
                                       FontSize="12" />
                            </VerticalStackLayout>
                            
                            <Border Grid.Column="1" 
                                    Stroke="#8A8A8A" 
                                    StrokeThickness="1" 
                                    StrokeShape="RoundRectangle 15" 
                                    HeightRequest="30" 
                                    WidthRequest="30"
                                    BackgroundColor="Transparent"
                                    VerticalOptions="Center">
                                <Label Text="✓" 
                                       TextColor="#8A8A8A" 
                                       HorizontalOptions="Center" 
                                       VerticalOptions="Center" 
                                       FontSize="14"/>
                                </Border>
                            
                        </Grid>
                        
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>