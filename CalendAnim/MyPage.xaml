<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CalendAnim.MyPage"
             Title="Ma Liste">

    <Grid Padding="20">
        <CollectionView ItemsSource="{Binding MesFavoris}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout Spacing="15" Padding="0, 0, 0, 15">
                        <Image Source="{Binding ImageUrl}" 
                               HeightRequest="80" 
                               WidthRequest="60" 
                               Aspect="AspectFill" />
                        <Label Text="{Binding Title}" 
                               FontAttributes="Bold" 
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>

</ContentPage>